# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Pterodactyl Panel Configuration
PTERODACTYL_URL=https://panel.yourdomain.com/api/application
PTERODACTYL_API_KEY=ptla_your_api_key_here

# OxaPay Cryptocurrency Payment Gateway
# Get your merchant key from https://app.oxapay.com/merchant
OXAPAY_MERCHANT_KEY=your_merchant_api_key_here
# Webhook secret for HMAC verification (if different from merchant key)
OXAPAY_WEBHOOK_SECRET=
# Callback URL where OxaPay sends payment status webhooks
OXAPAY_CALLBACK_URL=https://yourdomain.com/api/payments/oxapay/callback
# Return URL where users are redirected after payment
OXAPAY_RETURN_URL=https://yourdomain.com/dashboard/invoices
# Override the OxaPay API base URL (default: https://api.oxapay.com)
# OXAPAY_API_URL=https://api.oxapay.com
